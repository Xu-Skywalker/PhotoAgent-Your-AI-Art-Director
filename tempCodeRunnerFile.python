import numpy as np
import pandas as pd
from scipy.optimize import minimize

# 1. 设定真实参数
# lambda_true: 用户点击页面的概率
# beta_A, beta_B: 房型 A 和 B 的效用参数
lambda_true = 0.7
beta_true = np.array([1.5, 0.8])  # [beta_A, beta_B]

def mnl_probabilities(beta):
    """计算 MNL 模型下的选择概率 (包含不预定 0)"""
    exp_u = np.exp(beta)
    sum_exp = np.sum(exp_u) + 1  # 这里的 1 代表“不预定”的效用 exp(0)
    p_A = exp_u[0] / sum_exp
    p_B = exp_u[1] / sum_exp
    p_none = 1 / sum_exp
    return np.array([p_A, p_B, p_none])

# 2. 用 MNL 规则仿真生成数据
np.random.seed(42)
n_days = 1000  # 模拟 1000 天的数据
data = []

for day in range(n_days):
    # 第一步：模拟是否点击 (lambda)
    clicked = np.random.rand() < lambda_true
    
    if not clicked:
        # 无预定 (无点击行为)
        data.append({'day': day, 'action': 'no_click', 'choice': None})
    else:
        # 第二步：如果点击了，根据 MNL 选择 A, B 或 不预定
        probs = mnl_probabilities(beta_true)
        choice = np.random.choice(['A', 'B', 'no_book'], p=probs)
        data.append({'day': day, 'action': 'click', 'choice': choice})

df = pd.DataFrame(data)

# 3. 构建似然函数 (MLE)
def neg_log_likelihood(params, df):
    """计算负对数似然函数"""
    lmbda = params[0]
    beta = params[1:]
    
    # 约束 lambda 在 0 到 1 之间
    if lmbda <= 0 or lmbda >= 1:
        return 1e10
    
    p_A, p_B, p_none = mnl_probabilities(beta)
    
    ll = 0
    # 情况 1: 无点击 (1 - lambda)
    n_no_click = len(df[df['action'] == 'no_click'])
    ll += n_no_click * np.log(1 - lmbda)
    
    # 情况 2: 点击了且订了 A (lambda * p_A)
    n_A = len(df[df['choice'] == 'A'])
    ll += n_A * np.log(lmbda * p_A)
    
    # 情况 3: 点击了且订了 B (lambda * p_B)
    n_B = len(df[df['choice'] == 'B'])
    ll += n_B * np.log(lmbda * p_B)
    
    # 情况 4: 点击了但没预定 (lambda * p_none)
    n_no_book = len(df[df['choice'] == 'no_book'])
    ll += n_no_book * np.log(lmbda * p_none)
    
    return -ll  # 返回负值用于最小化

# 4. 执行参数估计
initial_guess = [0.5, 0.0, 0.0]  # 初始猜测值
result = minimize(neg_log_likelihood, initial_guess, args=(df,), method='L-BFGS-B', 
                  bounds=[(0.001, 0.999), (None, None), (None, None)])

est_lambda = result.x[0]
est_beta = result.x[1:]

# 5. 对比结果
print("--- 参数估计结果对比 ---")
print(f"参数 \t\t 设定真实值 \t MLE估计值")
print(f"Lambda (点击率)\t {lambda_true:.4f} \t\t {est_lambda:.4f}")
print(f"Beta_A (效用A)\t {beta_true[0]:.4f} \t\t {est_beta[0]:.4f}")
print(f"Beta_B (效用B)\t {beta_true[1]:.4f} \t\t {est_beta[1]:.4f}")

if np.allclose([lambda_true, *beta_true], result.x, atol=0.1):
    print("\n结论：估计参数与真实参数接近")

# =====================================================================
# 进阶实验：删除到达记录，比较 朴素MLE 与 EM算法 的参数估计
# =====================================================================

# 1. 制造观测数据（缺失到达记录）
# 在实际平台中，我们只能看到“订了A”、“订了B”、“今天没有订单(0)”
# 我们将原数据中的 'no_click' 和 'no_book' 统一视为观测不到的 '0' (无订单)
observed_data = []
for index, row in df.iterrows():
    if row['action'] == 'no_click' or row['choice'] == 'no_book':
        observed_data.append('0')
    else:
        observed_data.append(row['choice'])

df_obs = pd.DataFrame({'observed_choice': observed_data})

# 统计观测频次
N_A = len(df_obs[df_obs['observed_choice'] == 'A'])
N_B = len(df_obs[df_obs['observed_choice'] == 'B'])
N_0 = len(df_obs[df_obs['observed_choice'] == '0'])
N_total = len(df_obs)

print(f"--- 观测数据统计 ---")
print(f"订单A: {N_A} 天, 订单B: {N_B} 天, 无订单(0): {N_0} 天, 总计: {N_total} 天\n")


# 2. 朴素 MLE 估计 (默认 0 全是“到达没买”)
# 此时我们假设每天都有顾客到达，即隐含认定 lambda 趋近于 1
def naive_mle_nll(params):
    lmbda = params[0]
    beta = params[1:]
    
    if lmbda <= 0 or lmbda >= 1:
        return 1e10
        
    p_A, p_B, p_none = mnl_probabilities(beta)
    
    # 所有的 N_0 都被当作“点击了且没买”(lambda * p_none)
    ll = N_A * np.log(lmbda * p_A) + \
         N_B * np.log(lmbda * p_B) + \
         N_0 * np.log(lmbda * p_none)
    return -ll

result_naive = minimize(naive_mle_nll, [0.5, 0.0, 0.0], method='L-BFGS-B',
                        bounds=[(0.001, 0.999), (None, None), (None, None)])
naive_lambda = result_naive.x[0]
naive_beta = result_naive.x[1:]


# 3. EM 算法估计 (将“到达(click)”作为隐变量处理)
em_lambda = 0.5  # 初始化
em_beta = np.array([0.0, 0.0]) # 初始化
max_iter = 100
tol = 1e-5

for iteration in range(max_iter):
    # E-Step (期望步): 计算无订单天数中，真实有到达的概率 w (权重)
    p_A, p_B, p_none = mnl_probabilities(em_beta)
    # w = P(click | observed 0)
    w = (em_lambda * p_none) / (em_lambda * p_none + 1 - em_lambda)
    
    # M-Step (最大化步): 更新参数
    # 更新 lambda: 期望到达天数 / 总天数
    expected_clicks = N_A + N_B + N_0 * w
    new_lambda = expected_clicks / N_total
    
    # 更新 beta: 只对“确认到达的A、B”和“带期望权重的没买”做极大似然估计
    def em_m_step_nll(beta_params):
        p_A_temp, p_B_temp, p_none_temp = mnl_probabilities(beta_params)
        ll = N_A * np.log(p_A_temp) + \
             N_B * np.log(p_B_temp) + \
             (N_0 * w) * np.log(p_none_temp)
        return -ll
    
    res_em_beta = minimize(em_m_step_nll, em_beta, method='BFGS')
    new_beta = res_em_beta.x
    
    # 检查收敛条件
    if abs(new_lambda - em_lambda) < tol and np.linalg.norm(new_beta - em_beta) < tol:
        em_lambda = new_lambda
        em_beta = new_beta
        print(f"EM 算法在第 {iteration+1} 次迭代后收敛。\n")
        break
        
    em_lambda = new_lambda
    em_beta = new_beta


# 4. 打印最终对比结果
print("==========================================================")
print(f"{'参数':<12} | {'设定真实值':<10} | {'朴素 MLE估计':<12} | {'EM 算法估计':<10}")
print("-" * 58)
print(f"{'Lambda(点击率)':<10} | {lambda_true:<12.4f} | {naive_lambda:<14.4f} | {em_lambda:<10.4f}")
print(f"{'Beta_A(效用A)':<10} | {beta_true[0]:<12.4f} | {naive_beta[0]:<14.4f} | {em_beta[0]:<10.4f}")
print(f"{'Beta_B(效用B)':<10} | {beta_true[1]:<12.4f} | {naive_beta[1]:<14.4f} | {em_beta[1]:<10.4f}")
print("==========================================================")